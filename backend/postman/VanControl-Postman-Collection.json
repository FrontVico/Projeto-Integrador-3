  "item": [
    {
      "name": "Autenticação",
      "description": "Endpoints de autenticação e registro de usuários",
      "item": [
        {
          "name": "Registrar Usuário",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"token\", jsonData.token);",
                  "  pm.environment.set(\"userName\", jsonData.name);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João da Silva\",\n  \"email\": \"joao@example.com\",\n  \"password\": \"Senha123\",\n  \"cpf\": \"12345678901\",\n  \"telefone\": \"11223-4567\",\n  \"instituicaoEnsino\": \"Universidade Federal\",\n  \"turno\": \"Manhã\",\n  \"endereco\": \"Rua Exemplo, 123, Bairro, Cidade, SP\",\n  \"cep\": \"12345-678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
