{
  "info": {
    "name": "VanControl API Collection",
    "description": "Coleção completa da API VanControl - Sistema de gerenciamento de transporte de van para estudantes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
